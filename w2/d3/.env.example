# Copy this to .env and fill in your values
# cp .env.example .env

# --- Groq ---
GROQ_API_KEY=gsk_your_key_here

# --- Pipeline tuning (optional) ---
AIOPS_USE_LLM=true
AIOPS_LLM_MODEL=llama-3.3-70b-versatile   # or: mixtral-8x7b-32768, llama-3.1-8b-instant
AIOPS_CORRELATE_GAP_SEC=120
AIOPS_CORRELATE_MAX_HOP=2
AIOPS_GRAPH_RELOAD_SEC=300

# --- Dataset paths (optional, defaults to dataset/ beside pipeline.py) ---
# AIOPS_SERVICES_JSON=dataset/services.json
# AIOPS_HISTORY_JSON=dataset/incidents_history.json
